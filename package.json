{
  "name": "browser-agent",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript browser automation: SDK + CLI/MCP runtime.",
  "homepage": "https://github.com/peteqian/browser-agent#readme",
  "bugs": {
    "url": "https://github.com/peteqian/browser-agent/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/peteqian/browser-agent.git"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "evals/*"
  ],
  "type": "module",
  "scripts": {
    "build": "turbo build --filter=!./apps/*",
    "typecheck": "turbo typecheck --filter=!./apps/*",
    "lint": "turbo lint --filter=!./apps/*",
    "test": "turbo test --filter=!./apps/*",
    "fmt": "oxfmt --ignore-path .gitignore --ignore-path .oxfmtignore",
    "fmt:check": "oxfmt --check --ignore-path .gitignore --ignore-path .oxfmtignore",
    "changeset": "changeset",
    "version-packages": "changeset version && bun install",
    "release": "turbo build && node scripts/publish.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@types/node": "^25.1.0",
    "oxfmt": "^0.50.0",
    "oxlint": "^1.68.0",
    "tsup": "^8.5.1",
    "turbo": "^2.9.16",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14"
}
