{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "import"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn"
  },
  "rules": {
    "no-underscore-dangle": [
      "error",
      { "allow": ["_meta", "__PACKAGE_VERSION__", "__PACKAGE_NAME__"] }
    ],
    "unicorn/consistent-function-scoping": "off"
  },
  "ignorePatterns": ["dist", "node_modules", ".tsbuildinfo*", "docs/api"]
}
